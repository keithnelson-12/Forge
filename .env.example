# Forge Middleware Configuration

# Port Forge listens on
FORGE_PORT=4100

# Full base URL of the Development Harness API (e.g. http://10.20.0.85:4000)
HARNESS_URL=http://localhost:4000

# Path to the SQLite database file for the container registry
FORGE_DB_PATH=./forge.db

# Shared secret for authenticating container plugin calls (X-Forge-Key header)
FORGE_API_KEY=change-me-to-a-secure-random-key
