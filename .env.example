# Forge Middleware Configuration
# Copy this file to .env and fill in ALL required values before starting Forge.
# Every variable without a default is REQUIRED — the server will refuse to start if omitted.

# Port Forge listens on — REQUIRED, no default
FORGE_PORT=

# Full base URL of the Development Harness API — REQUIRED, no default
HARNESS_URL=

# Path to the SQLite database file for the container registry — REQUIRED, no default
FORGE_DB_PATH=

# Shared secret for authenticating container plugin calls (x-forge-key header)
# REQUIRED — server will not start without this
FORGE_API_KEY=
