# ─── Forge Container Configuration ───────────────────────────────────────────
# Copy this file to .env and fill in the values before starting the container.

# ─── Forge Middleware Connection ─────────────────────────────────────────────
# Full URL of the Forge middleware (never localhost — use the actual host IP/domain)
FORGE_URL=http://10.20.0.85:4100

# Shared secret for authenticating with Forge (must match FORGE_API_KEY on the Forge server)
FORGE_API_KEY=change-me-to-a-secure-secret

# ─── Container Identity ─────────────────────────────────────────────────────
# Unique ID for this container — must be unique across all containers
CONTAINER_ID=my-project-container

# Human-readable project name (must match a registered project in the Dev Harness)
PROJECT_NAME=my-project

# GitHub repository this container manages
REPO_URL=https://github.com/your-org/your-repo

# ─── Telegram Bot ────────────────────────────────────────────────────────────
# Create a new bot via @BotFather on Telegram, then paste the token here
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Chat ID for notifications — send /start to your bot, then use the Telegram API
# to find your chat ID: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=123456789

# ─── Container Settings ─────────────────────────────────────────────────────
# Port the thin plugin HTTP server listens on inside the container
PLUGIN_PORT=8080

# Log level (debug, info, warn, error)
LOG_LEVEL=info
